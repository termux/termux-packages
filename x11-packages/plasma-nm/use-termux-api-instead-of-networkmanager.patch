 PlasmoidItem {
     id: mainWindow
 
+/* ifdef TERMUX */
+    property var wifiJson: ({})
+    property var mobileJson: ({})
+
+    readonly property bool wifiConnected: wifiJson.supplicant_state === "COMPLETED"
+    readonly property bool mobileConnected: mobileJson.data_state === "connected"
+    readonly property string operatorName: mobileJson.network_operator_name ?? ""
+
+    readonly property string wifiIcon: {
+        const rssi = wifiJson.rssi ?? -100
+        if (rssi >= -55) return "network-wireless-connected-100"
+        if (rssi >= -65) return "network-wireless-connected-75"
+        if (rssi >= -75) return "network-wireless-connected-50"
+        if (rssi >= -85) return "network-wireless-connected-25"
+        return "network-wireless-connected-00"
+    }
+
+    readonly property string mobileIconName: {
+        const t = (mobileJson.network_type ?? "").toLowerCase()
+        if (t === "nr" || t === "nrnsa") return "network-mobile-100-5g"
+        if (t === "lte" || t === "lte_ca") return "network-mobile-100-lte"
+        if (t === "hspa") return "network-mobile-100-hspa"
+        if (t === "hsupa") return "network-mobile-100-hsupa"
+        if (t === "hsdpa" || t === "hspap") return "network-mobile-100-hsdpa"
+        if (t === "umts") return "network-mobile-100-umts"
+        if (t === "edge") return "network-mobile-100-edge"
+        if (t === "gprs") return "network-mobile-100-gprs"
+        return "network-mobile-100"
+    }
+
+    readonly property string mobileIcon: {
+        const found = StandardPaths.locate(
+            StandardPaths.GenericDataLocation,
+            "icons/breeze/status/22/" + mobileIconName + ".svg"
+        )
+        const fallback = StandardPaths.locate(
+            StandardPaths.GenericDataLocation,
+            "icons/breeze/status/22/network-mobile-100.svg"
+        )
+        return found !== "" ? found : fallback
+    }
+
+    toolTipMainText: i18n("Networks")
+    toolTipSubText: wifiConnected ? i18n("Wi-Fi Connected")
+                  : mobileConnected ? operatorName
+                  : i18n("Disconnected")
+
+    Plasmoid.busy: false
+    Plasmoid.icon: wifiConnected ? wifiIcon
+                 : mobileConnected ? mobileIcon
+                 : "network-disconnect-symbolic"
+
+    switchWidth: Kirigami.Units.gridUnit * 10
+    switchHeight: Kirigami.Units.gridUnit * 10
+
+    fullRepresentation: PopupDialog {
+        id: dialogItem
+        wifiConnected: mainWindow.wifiConnected
+        mobileConnected: mainWindow.mobileConnected
+        operatorName: mainWindow.operatorName
+        mobileIcon: mainWindow.mobileIcon
+        wifiIcon: mainWindow.wifiIcon
+        Layout.minimumWidth: Kirigami.Units.iconSizes.medium * 10
+        Layout.minimumHeight: Kirigami.Units.gridUnit * 10
+        anchors.fill: parent
+        focus: true
+    }
+/* else
