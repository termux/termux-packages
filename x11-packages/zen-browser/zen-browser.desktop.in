[Desktop Entry]
Version=1.0
Name=Zen Browser
Comment=Zen Browser - Push your productivity to a new level
GenericName=Web Browser
Keywords=Internet;WWW;Browser;Web;Explorer;Zen
Exec=@TERMUX_PKG_NAME@ %u
Terminal=false
X-MultipleArgs=false
Type=Application
Icon=@TERMUX_PKG_NAME@
Categories=GNOME;GTK;Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;application/xml;application/rss+xml;application/rdf+xml;image/gif;image/jpeg;image/png;x-scheme-handler/http;x-scheme-handler/https;video/webm;application/x-xpinstall;
StartupNotify=true
StartupWMClass=@TERMUX_PKG_NAME@
Actions=new-window;new-blank-window;new-private-window;profilemanager;

[Desktop Action new-window]
Name=Open a New Window
Exec=@TERMUX_PKG_NAME@ --new-window

[Desktop Action new-blank-window]
Name=Open a New Blank Window
Exec=@TERMUX_PKG_NAME@ --blank-window

[Desktop Action new-private-window]
Name=Open a New Private Window
Exec=@TERMUX_PKG_NAME@ --private-window

[Desktop Action profilemanager]
Name=Profile Manager
Exec=@TERMUX_PKG_NAME@ --ProfileManager
