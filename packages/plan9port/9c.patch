--- a/bin/9c
+++ b/bin/9c
@@ -30,6 +30,10 @@ usegcc()
 	# that option only works with gcc3+ it seems
 	cflags="$cflags -ggdb"
 	cflags="$cflags $CC9FLAGS"
+	if [ "$_P9P_BOOTSTRAP" = 'true' ]
+	then
+		cflags="-c $CFLAGS"
+	fi
 }
 
 quiet()
@@ -89,6 +93,10 @@ useclang()
 	"
 	cflags="$cflags -g"
 	cflags="$cflags $CC9FLAGS"
+	if [ "$_P9P_BOOTSTRAP" = 'true' ]
+	then
+		cflags="-c $CFLAGS"
+	fi
 }
 
 usexlc()
@@ -107,6 +115,10 @@ usexlc()
 	"
 	cflags="$cflags -g -qdbxextra -qfullpath"
 	cflags="$cflags $CC9FLAGS"
+	if [ "$_P9P_BOOTSTRAP" = 'true' ]
+	then
+		cflags="-c $CFLAGS"
+	fi
 }
 
 tag="${SYSNAME:-`uname`}-${CC9:-cc}"
@@ -118,14 +130,7 @@ case "$tag" in
 		cflags="$cflags -g3 -m64"
 		;;
 *HP-UX*)	cc=${CC9:-cc}; cflags="-g -O -c -Ae" ;;
-*Linux*)	usegcc
-		case "${CC9:-gcc}" in
-		tcc)
-			cc=tcc
-			cflags="-c -g"
-			;;
-		esac
-		;;
+*Linux*)	useclang ;;
 *OSF1*)		cc=${CC9:-cc}; cflags="-g -O -c" ;;
 *SunOS*-cc)	cc=cc;
 		cflags="-mt -g -O -c -xCC -D__sun__"
@@ -150,7 +155,7 @@ case "$tag" in
 esac
 
 # Must use temp file to avoid pipe; pipe loses status.
-xtmp=${TMPDIR-/tmp}/9c.$$.$USER.out
+xtmp=${TMPDIR-@TERMUX_PREFIX@/tmp}/9c.$$.$USER.out
 $cc -DPLAN9PORT -I"$PLAN9/include" $cflags "$@" 2>"$xtmp"
 status=$?
 quiet "$xtmp"
