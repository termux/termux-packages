--- a/bin/9l
+++ b/bin/9l
@@ -25,9 +25,14 @@ case "$tag" in
 	nmflags="-B"
 	;;
 *Linux*)
-	ld="${CC9:-gcc} $CC9FLAGS"
+	if [ "$bootstrap" = 'true' ]
+	then
+		ld="${CC9:-clang} $CC9FLAGS -L@TERMUX_PREFIX@/lib"
+	else
+		ld="$CC $CFLAGS -L@TERMUX_PREFIX@/lib"
+	fi
 	userpath=true
-	extralibs="$extralibs -lutil -lresolv -lpthread"
+	extralibs="$extralibs -lutil -lresolv_wrapper -lpthread"
 	;;
 *Darwin*)
 	ld="${CC9:-gcc} -m64 $CC9FLAGS"
@@ -342,7 +347,7 @@ quiet()
 }
 
 # Must use temp file to avoid pipe; pipe loses status.
-xtmp=${TMPDIR-/tmp}/9l.$$.$USER.out
+xtmp=${TMPDIR-@TERMUX_PREFIX@/tmp}/9l.$$.$USER.out
 $ld -L"$PLAN9/lib" "$@" $libsl $extralibs $frameworks >"$xtmp" 2>&1
 status=$?
 quiet "$xtmp"
