 		"bindbc-opengl": "1.0.5",
 		"bindbc-sdl": "1.0.1",
-		"botan": "1.13.6",
+		"botan": "~master",
 		"botan-math": "1.0.4",
 		"cachetools": "0.4.1",
 		"concepts": "0.0.9",
@@ -34,7 +34,6 @@
