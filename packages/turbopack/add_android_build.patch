+#[cfg(target_os = "android")]
+fn simple_base64_decode(input: &str) -> Result<Vec<u8>, ()> {
+    let mut buffer = Vec::new();
+    let mut bits: u32 = 0;
+    let mut bit_count = 0;
+    for byte in input.bytes() {
+        let val = match byte {
+            b'A'..=b'Z' => byte - b'A',
+            b'a'..=b'z' => byte - b'a' + 26,
+            b'0'..=b'9' => byte - b'0' + 52,
+            b'+' => 62,
+            b'/' => 63,
+            b'=' => continue,
+            _ => continue,
+        };
+        bits = (bits << 6) | (val as u32);
+        bit_count += 6;
+        if bit_count >= 8 {
+            bit_count -= 8;
+            buffer.push((bits >> bit_count) as u8);
+            bits &= (1 << bit_count) - 1;
+        }
+    }
+    Ok(buffer)
+}
