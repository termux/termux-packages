 /*
  * splint note: In a few places, "#if SPLINT" is used to substitute other
@@ -688,7 +689,23 @@
  * 0.
  *
  * Returns the total number of bytes transferred, or negative on error.
+ *
+ * Wrapper that uses syscall for copy_file_range, so it works even when libc
+ * doesn't expose the function (Android < API 34). Returns -1 with errno
+ * set if kernel doesn't support the syscall.
  */
+static ssize_t
+runtime_copy_file_range(int fd_in, off64_t *off_in, int fd_out,
+                        off64_t *off_out, size_t len, unsigned flags)
+{
+#ifdef __NR_copy_file_range
+    return syscall(__NR_copy_file_range, fd_in, off_in, fd_out, off_out, len, flags);
+#else
+    errno = ENOSYS;
+    return -1;
+#endif
+}
+
 static ssize_t pv__transfer__copy_file_range_repeated(pvstate_t state, int input_fd, int output_fd,
 						      off_t max_to_read, off_t max_to_write, bool *transfer_attempted)
 {
@@ -740,7 +757,7 @@
