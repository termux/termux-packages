From: Laurent Rineau <laurent.rineau@cgal.org>
Date: Mon, 22 Jun 2026 15:59:41 +0200
Subject: [PATCH] fix issue #9530

---
 Number_types/include/CGAL/GMP/Gmpzf_type.h | 13 +++++++++++++
 1 file changed, 13 insertions(+)

--- a/include/CGAL/GMP/Gmpzf_type.h
+++ b/include/CGAL/GMP/Gmpzf_type.h
@@ -562,12 +562,25 @@ bool operator<(const Gmpzf &a, int b)
   return operator<(a, Gmpzf(b));
 }
 
+inline
+bool operator<(const Gmpzf &a, double d)
+{
+  return operator<(a, Gmpzf(d));
+}
+
 inline
 bool operator==(const Gmpzf &a, int b)
 {
   return operator==(a, Gmpzf(b));
 }
 
+inline
+bool operator==(const Gmpzf &a, double d)
+{
+  return operator==(a, Gmpzf(d));
+}
+
+
 inline
 bool operator>(const Gmpzf &a, int b)
 {
